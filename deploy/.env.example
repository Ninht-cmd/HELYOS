# HELYOS — variables d'environnement (exemple).
# Copier en .env et adapter. NE JAMAIS committer de secrets réels.

# --- Kernel ---
HELYOS_APP_NAME=HELYOS Jarvis Kernel
HELYOS_HOST=127.0.0.1
HELYOS_PORT=8080
# Niveau d'autonomie par défaut (A0..A5). Défaut sûr : A1 (préparer, ne pas agir).
HELYOS_DEFAULT_AUTONOMY=A1

# --- PostgreSQL ---
POSTGRES_USER=helyos
POSTGRES_PASSWORD=change-me
POSTGRES_DB=helyos

# --- MinIO ---
MINIO_USER=helyos
MINIO_PASSWORD=change-me-secret

# --- Grafana ---
GRAFANA_PASSWORD=change-me
